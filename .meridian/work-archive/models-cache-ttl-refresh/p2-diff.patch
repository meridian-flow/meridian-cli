+
+        let (_cache, outcome) = ensure_fresh(mars.path(), 24, RefreshMode::Auto).unwrap();
+        assert_eq!(outcome, RefreshOutcome::AlreadyFresh);
+        assert_eq!(mock.hits(), 0);
+    }
